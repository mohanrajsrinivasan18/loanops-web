generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// BUSINESS / TENANT
// ============================================================

model Tenant {
  id               String   @id @default(cuid())
  name             String
  code             String   @unique
  businessType     String   @default("lending")
  businessCategory String?
  ownerName        String?
  ownerPhone       String?
  ownerEmail       String?
  gstNumber        String?
  address          String?
  logo             String?
  status           String   @default("active")
  plan             String   @default("starter")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  Agent            Agent[]
  Collection       Collection[]
  Customer         Customer[]
  Line             Line[]
  LineDailyFinance LineDailyFinance[]
  Loan             Loan[]
  Chit             Chit[]
  Expense          Expense[]
  TenantSettings   TenantSettings?
  User             User[]
  AuditLog         AuditLog[]
  Transaction      Transaction[]
  
  // SaaS Platform Relations
  Subscription     TenantSubscription[]
  Limits           TenantLimit?
  Usage            TenantUsage[]
  Features         TenantFeature[]
  Products         TenantProduct[]
  Invoices         Invoice[]

  @@index([businessType])
  @@index([status])
}

model TenantSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  brandName       String?
  brandLogo       String?
  primaryColor    String   @default("#3b82f6")
  secondaryColor  String   @default("#8b5cf6")
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  dateFormat      String   @default("DD/MM/YYYY")
  defaultInterestRate Float @default(12)
  defaultTenure   Int      @default(12)
  minLoanAmount   Float    @default(5000)
  maxLoanAmount   Float    @default(500000)
  reminderDaysBefore Int   @default(3)
  overdueGraceDays Int     @default(3)
  smsEnabled      Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  whatsappEnabled Boolean  @default(false)
  agentVisibility Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  phone       String?
  password    String
  role        String
  status      String    @default("active")
  tenantId    String?
  agentId     String?   @unique
  customerId  String?   @unique
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  Agent       Agent?    @relation(fields: [agentId], references: [id])
  Customer    Customer? @relation(fields: [customerId], references: [id])

  @@index([email])
  @@index([tenantId])
  @@index([phone])
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ============================================================
// AGENTS
// ============================================================

model Agent {
  id               String       @id @default(cuid())
  name             String
  phone            String
  email            String?
  area             String?
  status           String       @default("active")
  targetCollection Float        @default(0)
  isShadowAgent    Boolean      @default(false)
  tenantId         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  Tenant           Tenant       @relation(fields: [tenantId], references: [id])
  Collection       Collection[]
  Customer         Customer[]
  Line             Line[]
  Loan             Loan[]
  Chit             Chit[]
  User             User?

  @@index([status])
  @@index([tenantId])
  @@index([phone])
  @@index([isShadowAgent])
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id         String       @id @default(cuid())
  name       String
  phone      String
  email      String?
  address    String       @default("")
  aadhaar    String?
  pan        String?
  area       String?
  lat        Float?
  lng        Float?
  status     String       @default("active")
  agentId    String?
  lineId     String?
  tenantId   String
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Agent      Agent?       @relation(fields: [agentId], references: [id])
  Line       Line?        @relation(fields: [lineId], references: [id])
  Tenant     Tenant       @relation(fields: [tenantId], references: [id])
  Collection Collection[]
  Loan       Loan[]
  ChitMember ChitMember[]
  User       User?

  @@index([agentId])
  @@index([lineId])
  @@index([phone])
  @@index([tenantId])
}

// ============================================================
// LOANS
// ============================================================

model Loan {
  id           String       @id @default(cuid())
  customerId   String
  amount       Float
  interestRate Float
  tenure       Int
  emi          Float
  outstanding  Float
  loanType     String       @default("monthly")
  status       String       @default("active")
  startDate    DateTime
  endDate      DateTime?
  agentId      String?
  tenantId     String
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  Collection   Collection[]
  Agent        Agent?       @relation(fields: [agentId], references: [id])
  Customer     Customer     @relation(fields: [customerId], references: [id])
  Tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([agentId])
  @@index([customerId])
  @@index([status])
  @@index([tenantId])
}

// ============================================================
// COLLECTIONS
// ============================================================

model Collection {
  id              String    @id @default(cuid())
  loanId          String
  customerId      String
  amount          Float
  method          String
  status          String    @default("pending")
  dueDate         DateTime
  collectedDate   DateTime?
  collectedAmount Float?
  agentId         String?
  tenantId        String
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  Agent           Agent?    @relation(fields: [agentId], references: [id])
  Customer        Customer  @relation(fields: [customerId], references: [id])
  Loan            Loan      @relation(fields: [loanId], references: [id])
  Tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([agentId])
  @@index([customerId])
  @@index([dueDate])
  @@index([loanId])
  @@index([status])
  @@index([tenantId])
}

// ============================================================
// CHIT FUNDS
// ============================================================

model Chit {
  id              String        @id @default(cuid())
  chitName        String
  chitValue       Float
  duration        Int
  memberCount     Int
  monthlyAmount   Float
  status          String        @default("active")
  startDate       DateTime
  endDate         DateTime?
  agentId         String?
  tenantId        String
  productType     String        @default("CHIT")
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ChitMembers     ChitMember[]
  ChitAuctions    ChitAuction[]
  ChitPayments    ChitPayment[]
  Agent           Agent?        @relation(fields: [agentId], references: [id])
  Tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([agentId])
  @@index([status])
  @@index([tenantId])
  @@index([productType])
}

model ChitMember {
  id              String        @id @default(cuid())
  chitId          String
  customerId      String
  memberNumber    Int
  status          String        @default("active")
  hasWonAuction   Boolean       @default(false)
  wonAuctionMonth Int?
  tenantId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  Chit            Chit          @relation(fields: [chitId], references: [id])
  Customer        Customer      @relation(fields: [customerId], references: [id])
  ChitPayments    ChitPayment[]

  @@unique([chitId, memberNumber, tenantId])
  @@index([chitId])
  @@index([customerId])
  @@index([tenantId])
}

model ChitAuction {
  id              String   @id @default(cuid())
  chitId          String
  monthNumber     Int
  auctionDate     DateTime
  winnerMemberId  String?
  bidAmount       Float?
  dividendAmount  Float?
  status          String   @default("pending")
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Chit            Chit     @relation(fields: [chitId], references: [id])

  @@unique([chitId, monthNumber, tenantId])
  @@index([chitId])
  @@index([tenantId])
}

model ChitPayment {
  id           String     @id @default(cuid())
  chitId       String
  chitMemberId String
  monthNumber  Int
  amount       Float
  paymentDate  DateTime?
  status       String     @default("pending")
  tenantId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Chit         Chit       @relation(fields: [chitId], references: [id])
  ChitMember   ChitMember @relation(fields: [chitMemberId], references: [id])

  @@index([chitId])
  @@index([chitMemberId])
  @@index([tenantId])
}

// ============================================================
// LINES & DAILY FINANCE
// ============================================================

model Line {
  id               String             @id @default(cuid())
  name             String
  area             String
  type             String             @default("daily")
  weeklyDay        String?
  interestRate     Float              @default(2.5)
  agentId          String?
  tenantId         String
  status           String             @default("active")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  Agent            Agent?             @relation(fields: [agentId], references: [id])
  Tenant           Tenant             @relation(fields: [tenantId], references: [id])
  Customer         Customer[]
  LineDailyFinance LineDailyFinance[]

  @@index([agentId])
  @@index([tenantId])
  @@index([area])
  @@index([status])
}

model LineDailyFinance {
  id               String   @id @default(cuid())
  lineId           String
  tenantId         String
  date             DateTime
  collectionAmount Float    @default(0)
  investmentAmount Float    @default(0)
  expenseAmount    Float    @default(0)
  notes            String?
  agentNotes       String?
  adminNotes       String?
  isLocked         Boolean  @default(false)
  lockedAt         DateTime?
  lockedByUserId   String?
  updatedByUserId  String?
  updatedByRole    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  Line             Line     @relation(fields: [lineId], references: [id])
  Tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([lineId, date])
  @@index([tenantId])
  @@index([date])
}

// ============================================================
// EXPENSES & TRANSACTIONS
// ============================================================

model Expense {
  id          String   @id @default(cuid())
  category    String
  amount      Float
  description String?
  date        DateTime
  agentId     String?
  tenantId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
  @@index([date])
}

model Transaction {
  id              String   @id @default(cuid())
  type            String
  status          String   @default("completed")
  totalAmount     Float
  paidAmount      Float    @default(0)
  balanceAmount   Float    @default(0)
  paymentMethod   String?
  customerId      String?
  agentId         String?
  referenceId     String?
  referenceType   String?
  notes           String?
  tenantId        String
  metadata        Json?
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([customerId])
  @@index([transactionDate])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  Tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([createdAt])
  @@index([entity])
  @@index([tenantId])
  @@index([userId])
}

// ============================================================
// SAAS PLATFORM - SUBSCRIPTION & BILLING
// ============================================================

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  billingCycle  String   // monthly, yearly
  features      Json     // {sms: true, whatsapp: false, mapAnalytics: true}
  limits        Json     // {maxUsers: 10, maxCustomers: 2000}
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  TenantSubscription TenantSubscription[]
  
  @@index([isActive])
}

model TenantSubscription {
  id         String   @id @default(cuid())
  tenantId   String
  planId     String
  status     String   // active, expired, cancelled, trial
  startDate  DateTime
  endDate    DateTime?
  autoRenew  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  Tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Plan    SubscriptionPlan @relation(fields: [planId], references: [id])
  Invoice Invoice[]
  
  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
}

model TenantLimit {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  maxUsers          Int      @default(3)
  maxCustomers      Int      @default(500)
  maxLoansPerMonth  Int      @default(1000)
  storageLimit      Int      @default(1024) // MB
  apiCallsPerDay    Int      @default(10000)
  smsCredits        Int      @default(100)
  whatsappCredits   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model TenantUsage {
  id              String   @id @default(cuid())
  tenantId        String
  date            DateTime @db.Date
  usersCount      Int      @default(0)
  customersCount  Int      @default(0)
  loansCount      Int      @default(0)
  storageUsed     Int      @default(0) // MB
  apiCalls        Int      @default(0)
  smsUsed         Int      @default(0)
  whatsappUsed    Int      @default(0)
  createdAt       DateTime @default(now())
  
  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([date])
}

model TenantFeature {
  id          String   @id @default(cuid())
  tenantId    String
  featureName String   // sms, whatsapp, mapAnalytics, advancedReports, customBranding, apiAccess, prioritySupport
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, featureName])
  @@index([tenantId])
  @@index([featureName])
}

// ============================================================
// PRODUCT CONTROL (Super Admin)
// ============================================================

model TenantProduct {
  id          String   @id @default(cuid())
  tenantId    String
  productType String   // LOAN, CHIT, GOLD_LOAN, PERSONAL_LOAN, INSURANCE, SAVINGS
  enabled     Boolean  @default(true)
  settings    Json?    // Product-specific settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, productType])
  @@index([tenantId])
  @@index([productType])
  @@index([enabled])
}

model Invoice {
  id              String   @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  invoiceNumber   String   @unique
  amount          Float
  tax             Float    @default(0)
  totalAmount     Float
  status          String   // pending, paid, failed, cancelled
  dueDate         DateTime
  paidDate        DateTime?
  paymentMethod   String?  // razorpay, stripe, bank_transfer, cash
  paymentId       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id])
  
  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
}

model PlatformAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  tenantId    String?
  action      String   // created_tenant, updated_plan, adjusted_limits, suspended_tenant, etc.
  entity      String   // tenant, plan, subscription, invoice, etc.
  entityId    String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([adminUserId])
  @@index([tenantId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
